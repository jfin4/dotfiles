#!/usr/bin/env zsh

# pull from cloud
pfc() {
    local remote=$1
    local dir=$2
    # -h prevent artifacts?
    tmux split-window -h -d "
        printf '%s\n' $remote:$dir
        for i in {1..78}; do printf '-'; done
        printf '\n'
        rclone --progress copy $remote:$dir ~/$dir \
            || exec sh
    "
}


#!/usr/bin/env zsh

# push to cloud
ptc() {
    local remote=$1
    local dir=$2
    # -h prevent artifacts?
    tmux split-window -h -d "
        printf '%s\n' $remote:$dir
        for i in {1..78}; do printf '-'; done
        printf '\n'
        rclone --progress --exclude 'archive/**' sync ~/$dir $remote:$dir \
            || exec sh
    "
}


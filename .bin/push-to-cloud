#!/usr/bin/env zsh

run_sync() {
    local store=$1; shift
    for dir in "$@"; do
        echo
        echo "$dir ------------------------------------------------------------------------------"
        rclone --progress --exclude "archive/**" sync ~/$dir $store:$dir 
    done
}

tmux split-window -h "zsh -c '$(typeset -f run_sync); run_sync docs notes projects records; exec zsh'"
tmux split-window -h "zsh -c '$(typeset -f run_sync); run_sync data resources; exec zsh'"

tmux select-layout main-vertical

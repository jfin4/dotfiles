#!/usr/bin/env zsh

path=/run/keyd-status
sudo touch $path
sudo chmod 777 $path
echo xwin > $path
while read -r line; do
    if [[ $line == /* ]]; then
        [[ $line == /xwin ]] && echo xwin > $path
        [[ $line == /tmux ]] && echo tmux > $path
        xsetroot -name "$(get-status)"
    fi
done < <(keyd listen)

#!/usr/bin/env zsh

sudo touch /run/keyd-status
sudo chmod 777 /run/keyd-status
echo xwin > /run/keyd-status
keyd listen | while read -r line; do
    if [[ $line == /* ]]; then
        [[ $line == /xwin ]] && echo xwin > /run/keyd-status
        [[ $line == /tmux ]] && echo tmux > /run/keyd-status
        xsetroot -name "$(get-status)"
    fi
done

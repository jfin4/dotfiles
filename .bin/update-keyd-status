#!/usr/bin/env zsh

if [[ -f /tmp/keyd-status ]]; then
    echo xwin > /tmp/keyd-status
    chmod 777 /tmp/keyd-status
fi 

keyd listen | while read -r line; do
    if [[ $line == /* ]]; then
        if [[ $line == /xwin ]]; then
            echo xwin > /tmp/keyd-status
        else
            echo tmux > /tmp/keyd-status
        fi
        xsetroot -name "$(get-status)"
    fi
done

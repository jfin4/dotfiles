# cwmrc(5)

# options
sticky yes
htile 60
vtile 60
borderwidth 2
color activeborder '#000000'
color inactiveborder '#ffffff'
fontname 'Terminus:size=20:weight=bold'
moveamount 1080

# unbind keys
unbind-key all

# key bindings
bind-key   MS-BackSpace  quit
bind-key   M-Return      terminal
bind-key   M-colon       menu-exec
bind-key   M-comma       get-status
bind-key   M-1           group-only-1
bind-key   M-2           group-only-2
bind-key   M-3           group-only-3
bind-key   M-4           group-only-4
bind-key   MS-1          window-movetogroup-1
bind-key   MS-2          window-movetogroup-2
bind-key   MS-3          window-movetogroup-3
bind-key   MS-4          window-movetogroup-4
bind-key   MS-j          group-cycle
bind-key   MS-k          group-rcycle
bind-key   M-Down        window-move-down
bind-key   M-Up          window-move-up
bind-key   M-j           window-cycle
bind-key   M-Tab         window-cycle
bind-key   M-k           window-rcycle
bind-key   M-BackSpace   window-close
bind-key   M-space       window-maximize
bind-key   M-o           window-htile
bind-key   M-i           window-vtile
bind-key   XF86AudioMute        "pactl set-sink-mute 0 toggle"
bind-key   XF86AudioMicMute     "pactl set-source-mute 1 toggle"
bind-key   XF86AudioRaiseVolume "pactl set-sink-volume 0 +5%"
bind-key   XF86AudioLowerVolume "pactl set-sink-volume 0 -5%"

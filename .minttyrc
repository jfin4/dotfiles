Font=Terminus (TTF) for Windows
FontHeight=12
ClipShortcuts=yes
WindowShortcuts=no
SwitchShortcuts=no
ZoomShortcuts=no
AltFnShortcuts=no
CursorType=block

ForegroundColour = #ffffff
BackgroundColour = #000000
CursorColour     = #ffffff

Black       = #000000
BoldBlack   = #696969
Blue        = #87cefa
BoldBlue    = #87cefa
Green       = #98bf98
BoldGreen   = #98bf98
Cyan        = #afeeee
BoldCyan    = #afeeee
Red         = #fa8072
BoldRed     = #fa8072
Magenta     = #dda0dd
BoldMagenta = #dda0dd
Yellow      = #eee8aa
BoldYellow  = #eee8aa
White       = #a9a9a9
BoldWhite   = #ffffff

ScrollbackLines=10000
Transparency=off
Scrollbar=none
Term=xterm-256color
FontWeight=500
FontIsBold=no
FontSmoothing=none
EmojiPlacement=stretch
Locale=en_US
Charset=UTF-8
BoldAsFont=yes
BoldAsColour=no
CursorBlinks=yes
Padding=16

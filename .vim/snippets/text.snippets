snippet todo
	#todo `strftime('%Y')`-\
	${1:`strftime('%m')`}-\
	${2:`strftime('%d')`} \
	`getline(search('#proj', 'wn'))[6:]` \
	${3:description}

snippet task
	`strftime('%m%d')`, \
	${1:`getline(line('.') - 1)[12:15]`}, \
	${3:time$0}, \
	${2:description}
	task

snippet time
	`strftime('%H%M', ((strftime('%s') + 450) / 900) * 900)`
